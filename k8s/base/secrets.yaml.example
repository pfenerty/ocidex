# ocidex-secrets — TEMPLATE ONLY
#
# This file is a documentation template. It is intentionally NOT listed in
# kustomization.yaml and will not be picked up by `kubectl kustomize`. Every
# workload in k8s/base/ references the Secret named `ocidex-secrets` via
# `envFrom: secretRef: { name: ocidex-secrets }` (postgres-statefulset.yaml uses
# `secretKeyRef` for POSTGRES_PASSWORD); this file documents what that Secret
# must contain.
#
# Where the real Secret comes from
# --------------------------------
# Dev cluster (Tilt/Talos):
#   Synthesized in-memory by Tiltfile from the repo-root .env file. You do not
#   need to populate this template for dev.
#
# Production (homelab Pi Talos cluster, ocidex.app):
#   Lives in the homelab repo at flux/apps/ocidex/secrets.enc.yaml,
#   SOPS-encrypted, applied by Flux. Owned by ocidex-0my.12. NEVER commit a
#   populated copy of this template into the ocidex repo — .gitignore excludes
#   the unsuffixed name `k8s/base/secrets.yaml` as a safety net.
#
# Populating this template (template -> real Secret)
# --------------------------------------------------
# Generate each value, paste into a working copy, then hand off to
# ocidex-0my.12 for SOPS encryption in the homelab repo.
#
#   SESSION_SECRET
#     openssl rand -hex 32
#     Used by gorilla/sessions to sign the auth cookie. Rotating it
#     invalidates every active session.
#
#   POSTGRES_PASSWORD
#     openssl rand -base64 24
#     base64 has no shell-special chars that would break the connection
#     string. Must match the password embedded in DATABASE_URL below.
#
#   DATABASE_URL
#     postgres://ocidex:<POSTGRES_PASSWORD>@postgres:5432/ocidex?sslmode=disable
#     In-cluster DNS (`postgres` is the StatefulSet service name).
#     sslmode=disable is fine because traffic never leaves the pod network.
#     Update this and POSTGRES_PASSWORD together.
#
#   GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET
#     From a GitHub *OAuth App* (NOT a fine-grained PAT, NOT a GitHub App).
#     Create at: github.com -> Settings -> Developer settings -> OAuth Apps ->
#     New OAuth App. Fields:
#       Application name:          OCIDex (homelab)
#       Homepage URL:              https://ocidex.app
#       Authorization callback URL: https://ocidex.app/auth/callback
#     OAuth scope requested at runtime: `read:user` only — set in
#     internal/service/auth.go (oauth2.Config.Scopes). Used to read the
#     authenticating user's profile and upsert the `users` row. Do not grant
#     `repo`, `read:org`, or `user:email` — they are not requested and granting
#     them would over-permission the app.
#     Client ID is public; Client Secret is shown once at generation. Both go
#     into the Secret below.
#
# Once values are pasted in, encrypt and apply via the homelab repo:
#   cp k8s/base/secrets.yaml.example <homelab>/flux/apps/ocidex/secrets.enc.yaml
#   # populate values
#   sops --encrypt --in-place <homelab>/flux/apps/ocidex/secrets.enc.yaml
#   git add / commit / push in the homelab repo; Flux reconciles.
#
# REPLACE_ME_* placeholders below will visibly fail any deployment that picks
# them up by accident — do not leave them in a working Secret.
---
apiVersion: v1
kind: Secret
metadata:
  name: ocidex-secrets
type: Opaque
stringData:
  SESSION_SECRET: "REPLACE_ME_openssl_rand_hex_32"
  POSTGRES_PASSWORD: "REPLACE_ME_openssl_rand_base64_24"
  DATABASE_URL: "postgres://ocidex:REPLACE_ME_POSTGRES_PASSWORD@postgres:5432/ocidex?sslmode=disable"
  GITHUB_CLIENT_ID: "REPLACE_ME_from_oauth_app"
  GITHUB_CLIENT_SECRET: "REPLACE_ME_from_oauth_app"
