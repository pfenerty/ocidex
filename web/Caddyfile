:80 {
	root * /srv
	encode gzip

	# Reverse-proxy API/auth/health paths to the backend.
	# Default targets the K8s Service name; compose overrides via BACKEND_URL.
	# In prod, the Gateway HTTPRoute peels /api off before traffic reaches Caddy,
	# so this is a no-op there for /api but covers /auth/callback (which the
	# HTTPRoute does not route).
	reverse_proxy /api/*  {$BACKEND_URL:http://ocidex-api:80}
	reverse_proxy /auth/* {$BACKEND_URL:http://ocidex-api:80}
	reverse_proxy /health {$BACKEND_URL:http://ocidex-api:80}
	reverse_proxy /ready  {$BACKEND_URL:http://ocidex-api:80}

	try_files {path} /index.html
	file_server
}
