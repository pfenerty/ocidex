:80 {
	encode gzip

	# Backend paths — explicit handle blocks take priority over the SPA fallback.
	# Default targets the K8s Service name; compose overrides via BACKEND_URL.
	# In prod, the Gateway HTTPRoute peels /api off before traffic reaches Caddy,
	# so this is a no-op there for /api but covers /auth/* (which the HTTPRoute
	# does not route).
	handle /api/* {
		reverse_proxy {$BACKEND_URL:http://ocidex-api:80}
	}
	handle /auth/* {
		reverse_proxy {$BACKEND_URL:http://ocidex-api:80}
	}
	handle /health {
		reverse_proxy {$BACKEND_URL:http://ocidex-api:80}
	}
	handle /ready {
		reverse_proxy {$BACKEND_URL:http://ocidex-api:80}
	}

	# SPA fallback — serve static files, fall back to index.html for client-side routing.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
