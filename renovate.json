{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "postUpdateOptions": ["gomodTidy"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "minor and patch dependencies",
      "automerge": true
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies",
      "automerge": true
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies",
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump base/tool image tags in the tektonic TypeScript source (.tektonic/**/*.ts) in lockstep with the generated .tekton/ YAML, so re-synthesis never reverts a Renovate bump.",
      "managerFilePatterns": ["/\\.tektonic/.*\\.ts$/"],
      "matchStrings": [
        "image:\\s*\"(?<depName>[^\":]+):(?<currentValue>[^\"]+)\"",
        "Image\\s*=\\s*\"(?<depName>[^\":]+):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
