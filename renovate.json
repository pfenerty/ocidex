{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "minor and patch dependencies",
      "automerge": true
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies",
      "automerge": true
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies",
      "automerge": true
    }
  ]
}
